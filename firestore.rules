rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // User profile + all user subcollections used by the app:
    // exercises, plans, sessions, bodyMetrics, progressPhotos, exerciseStats, etc.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Shared exercise catalog maintained out-of-band (admin/sync job).
    match /sharedExercises/{exerciseId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Deny anything outside /users/{uid}/...
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
