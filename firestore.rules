rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFriendRequestParticipant(fromUserId, toUserId) {
      return isSignedIn() && (request.auth.uid == fromUserId || request.auth.uid == toUserId);
    }

    function documentIdIncludesCurrentUser(documentId) {
      return isSignedIn()
        && (
          documentId.matches("^" + request.auth.uid + "__.+$")
          || documentId.matches("^.+__" + request.auth.uid + "$")
        );
    }

    function documentIdStartsWithCurrentUser(documentId) {
      return isSignedIn()
        && documentId.matches("^" + request.auth.uid + "__.+$");
    }

    function isFriend(userAId, userBId) {
      return isSignedIn()
        && (
          exists(/databases/$(database)/documents/friendships/$(userAId + "__" + userBId))
          || exists(/databases/$(database)/documents/friendships/$(userBId + "__" + userAId))
        );
    }

    // Public user profile at the root document, searchable by signed-in users.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);

      // Private user data lives in subcollections and remains owner-only.
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    match /friendRequests/{requestId} {
      allow read: if (
        resource != null
        && isFriendRequestParticipant(resource.data.fromUserId, resource.data.toUserId)
      ) || (
        resource == null
        && documentIdIncludesCurrentUser(requestId)
      );

      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.status == "pending";

      allow update: if isSignedIn()
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.toUserId == resource.data.toUserId
        && (
          (
            resource.data.fromUserId == request.auth.uid
            && request.resource.data.status == "pending"
          )
          || (
            resource.data.toUserId == request.auth.uid
            && resource.data.status == "pending"
            && request.resource.data.status in ["accepted", "declined"]
          )
        );

      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if (
        resource != null
        && isSignedIn()
        && request.auth.uid in resource.data.memberIds
      ) || (
        resource == null
        && documentIdIncludesCurrentUser(friendshipId)
      );

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == 2
        && request.resource.data.createdFromRequestId is string
        && getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.createdFromRequestId)).data.status == "accepted"
        && getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.createdFromRequestId)).data.friendshipId == friendshipId
        && request.auth.uid == getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.createdFromRequestId)).data.toUserId
        && getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.createdFromRequestId)).data.fromUserId in request.resource.data.memberIds
        && getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.createdFromRequestId)).data.toUserId in request.resource.data.memberIds;

      allow update, delete: if false;
    }

    match /sharedPlans/{sharedPlanId} {
      allow read: if (
        resource != null
        && isSignedIn()
        && (
          resource.data.ownerUserId == request.auth.uid
          || isFriend(resource.data.ownerUserId, request.auth.uid)
        )
      ) || (
        resource == null
        && documentIdStartsWithCurrentUser(sharedPlanId)
      );

      allow create: if isSignedIn()
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.sourcePlanId is string
        && request.resource.data.exerciseCount is int
        && request.resource.data.exerciseCount > 0;

      allow update: if resource != null
        && resource.data.ownerUserId == request.auth.uid
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.sourcePlanId == resource.data.sourcePlanId;

      allow delete: if resource != null
        && resource.data.ownerUserId == request.auth.uid;
    }

    // Shared exercise catalog maintained out-of-band (admin/sync job).
    match /sharedExercises/{exerciseId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Deny anything not matched explicitly above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
